{
  "name": "sneetches",
  "version": "1.0.0",
  "description": "Adds stars next to GitHub repo links",
  "author": "Oliver Steele <steele@osteele.com>",
  "license": "MIT",
  "main": "src/content.js",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:chrome": "make chrome",
    "build:firefox": "npm run build && web-ext build -s build -a dist -o && make source-zip",
    "build:watch": "npm run build --watch",
    "check": "tsc --noEmit",
    "dev": "webpack --mode development",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "prepare": "husky",
    "sampler": "python3 -m http.server 8000 & open-cli http://localhost:8000/examples/sampler",
    "test": "jest",
    "watch": "webpack --mode development --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kesensoy/sneetches.git"
  },
  "lint-staged": {
    "*.ts": ["prettier --write", "eslint --fix"]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.0.287",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-webextension-mock": "^3.9.0",
    "lint-staged": "^15.2.11",
    "open-cli": "^8.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "web-ext": "^8.3.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
